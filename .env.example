# --- Vaelan — variables d'environnement (copier en .env pour le dev local) ---
# Base de données : SQLite en local par défaut ; Postgres (Render) en prod.
DATABASE_URL=sqlite:///./vaelan.db
# Clé de signature des sessions (générer une vraie valeur en prod).
SECRET_KEY=dev-secret-change-me

# Admin initial créé au premier démarrage si la base est vide.
ADMIN_EMAIL=admin@vaelan.com
ADMIN_PASSWORD=changeme

# --- Clés API par société (jamais committées) ---
# Pennylane
PENNYLANE_STERNA_TOKEN=
PENNYLANE_STERNA_BASEURL=https://app.pennylane.com/api/external/v2
PENNYLANE_KOOKABURA_TOKEN=
PENNYLANE_KOOKABURA_BASEURL=https://app.pennylane.com/api/external/v2
# TopOrder — une variable par établissement (nom dérivé du nom d'établissement)
TOPORDER_BASEURL=https://publicproxy.toporder.fr
TOPORDER_OCOPAIN_SAINT_LEU_KEY=
TOPORDER_OCOPAIN_LA_POSSESSION_KEY=
TOPORDER_OCOPAIN_SAINTE_MARIE_KEY=
TOPORDER_KOOKABURA_KEY=
